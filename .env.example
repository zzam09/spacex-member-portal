# Supabase Configuration
# Get these from your Supabase project settings

# Your Supabase project URL
VITE_SUPABASE_URL=https://your-project.supabase.co

# Your Supabase anonymous/public key (safe to expose in frontend)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: Admin emails for temporary frontend bootstrap
# Format: comma-separated list of email addresses
# VITE_ADMIN_EMAILS=admin@example.com,superadmin@example.com
